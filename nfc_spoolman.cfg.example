# NFC Spoolman Daemon Configuration
# Place this file at ~/printer_data/config/nfc_spoolman.cfg

[nfc]
# Reader type: pn532, pn5180, acr1552u
reader = pn532

# ── PN532 settings (UART) ──────────────────────────────────
# Only TigerTag (ISO 14443A / NTAG213)
pn532_device = /dev/ttyUSB0
pn532_baudrate = 115200
# Legacy shorthand (also accepted): device = /dev/ttyUSB0:115200

# ── PN5180 settings (SPI) ──────────────────────────────────
# TigerTag + OpenPrintTag (ISO 14443A + ISO 15693)
# pn5180_spi_bus = 0
# pn5180_spi_cs = 0
# pn5180_busy_pin = 25
# pn5180_reset_pin = 24

# ── ACR1552U settings (USB / PC/SC) ────────────────────────
# TigerTag + OpenPrintTag (ISO 14443A + ISO 15693)
# acr1552u_reader_name = ACS ACR1552U

# ── Mode ────────────────────────────────────────────────────
# single:     One extruder — scanned spool is set as the global active spool
# multi_tool: Multiple tools (StealthChanger, IDEX, etc.) — shows a
#             KlipperScreen prompt to assign the scanned spool to a tool.
#             Requires [include nfc_macros.cfg] and [respond] in printer.cfg.
mode = single

# ── Common settings ─────────────────────────────────────────

# How often to poll for a tag (seconds)
poll_interval = 0.5

# Minimum seconds between activations of the same tag
debounce_time = 5.0

# Auto-create spool in Spoolman if tag not recognized
# (only for OpenPrintTag — creates vendor + filament + spool from tag data)
auto_create = false

# Update Mainsail preheat preset when a spool is detected
# Creates/updates an "NFC: ..." preset with extruder and bed temps from Spoolman
mainsail_preset = true

# Push filament metadata to Klipper via SAVE_VARIABLE
# Stores nfc_material, nfc_extruder_temp, nfc_bed_temp, etc. for use in macros
# Requires [save_variables] in printer.cfg
klipper_variables = true

[spoolman]
# URL of your Spoolman instance
url = http://localhost:7912

[moonraker]
# URL of the local Moonraker instance
url = http://localhost:7125
